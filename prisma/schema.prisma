// Zenith Medical Centre Database Schema
// HIPAA/PIPEDA Compliant Database Design

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Patient Intake Model (PHI Data - Encrypted)
model PatientIntake {
  id                    String   @id @default(cuid())
  
  // Personal Information (Encrypted)
  legalFirstName        String   // Encrypted
  legalLastName         String   // Encrypted
  preferredName         String?  // Encrypted
  dateOfBirth           String   // Encrypted (DD-MM-YYYY)
  phoneNumber           String   // Encrypted
  emailAddress          String   // Encrypted
  
  // Address Information (Encrypted)
  streetAddress         String   // Encrypted
  city                  String   // Encrypted
  provinceState         String   // Encrypted
  postalZipCode         String   // Encrypted
  
  // Emergency Contact (Encrypted)
  emergencyContactName  String   // Encrypted
  emergencyContactPhone String   // Encrypted
  relationshipToPatient String   // Encrypted
  
  // Consent and Compliance
  privacyPolicyAccepted Boolean
  consentTimestamp      DateTime @default(now())
  
  // Status Tracking
  status                IntakeStatus @default(SUBMITTED)
  appointmentBooked     Boolean      @default(false)
  appointmentBookedAt   DateTime?
  
  // Audit Trail
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  ipAddress             String?  // For audit purposes
  userAgent             String?  // For audit purposes
  
  // Relations
  appointments          Appointment[]
  
  @@map("patient_intakes")
}

// Admin Users Model
model AdminUser {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String
  role              AdminRole @default(ADMIN)
  
  // Security
  lastLoginAt       DateTime?
  loginAttempts     Int       @default(0)
  lockedUntil       DateTime?
  
  // Audit Trail
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  auditLogs         AuditLog[]
  
  @@map("admin_users")
}

// Content Management Models
model BlogPost {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  content     String
  excerpt     String?
  featured    Boolean     @default(false)
  published   Boolean     @default(false)
  publishedAt DateTime?
  
  // SEO
  metaTitle       String?
  metaDescription String?
  
  // Audit
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String
  
  @@map("blog_posts")
}

model FAQ {
  id          String   @id @default(cuid())
  question    String
  answer      String
  category    String?
  orderIndex  Int      @default(0)
  published   Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("faqs")
}

model TeamMember {
  id            String   @id @default(cuid())
  name          String
  title         String
  bio           String?
  photoUrl      String?
  email         String?
  phone         String?
  specialties   String[] // Array of specialties
  orderIndex    Int      @default(0)
  published     Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("team_members")
}

// Audit and Compliance
model AuditLog {
  id          String     @id @default(cuid())
  userId      String?
  action      String     // CREATE, READ, UPDATE, DELETE, LOGIN, etc.
  resource    String     // patient_intake, admin_user, etc.
  resourceId  String?
  details     Json?      // Additional context
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime   @default(now())
  
  // Relations
  user        AdminUser? @relation(fields: [userId], references: [id])
  
  @@map("audit_logs")
}

// Enums
enum IntakeStatus {
  SUBMITTED
  REVIEWED
  APPOINTMENT_SCHEDULED
  CHECKED_IN
  COMPLETED
  CANCELLED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

model Appointment {
  id                      String   @id @default(cuid())
  
  // Link to intake submission
  patientIntakeId         String?
  patientIntake           PatientIntake? @relation(fields: [patientIntakeId], references: [id], onDelete: SetNull)
  
  // Provider information
  providerType            String   // 'acuity', 'calendly', etc.
  providerAppointmentId   String?  // ID from the booking provider
  providerName            String?  // Name of the provider service
  
  // Patient information
  patientName             String
  patientEmail            String
  patientPhone            String
  
  // Appointment details
  appointmentDate         String
  appointmentTime         String
  appointmentType         String
  duration                Int?     // Duration in minutes
  
  // Provider/Doctor information
  providerId              String?
  providerStaffName       String?
  
  // Status and metadata
  status                  String   // 'scheduled', 'confirmed', 'cancelled', 'completed', 'no_show'
  notes                   String?
  reminderSent            Boolean  @default(false)
  confirmationSent        Boolean  @default(false)
  
  // Booking metadata
  bookingUrl              String?
  metadata                Json?    // Store provider-specific data
  
  // Timestamps
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  @@map("appointments")
}

model BookingProvider {
  id                      String   @id @default(cuid())
  
  // Provider details
  name                    String
  type                    String   // 'acuity', 'calendly', 'simplepractice', 'generic_webhook', 'embed'
  active                  Boolean  @default(false)
  isDefault               Boolean  @default(false)
  
  // Configuration
  config                  Json     // Store provider-specific configuration
  
  // Timestamps
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  @@unique([type])
  @@map("booking_providers")
}
