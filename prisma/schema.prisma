generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PatientIntake {
  id                      String        @id @default(cuid())
  legalFirstName          String
  legalLastName           String
  preferredName           String?
  dateOfBirth             String
  phoneNumber             String
  emailAddress            String
  healthInformationNumber String
  streetAddress           String
  city                    String
  provinceState           String
  postalZipCode           String
  nextOfKinName           String
  nextOfKinPhone          String
  relationshipToPatient   String
  privacyPolicyAccepted   Boolean
  consentTimestamp        DateTime      @default(now())
  status                  IntakeStatus  @default(SUBMITTED)
  appointmentBooked       Boolean       @default(false)
  appointmentBookedAt     DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  ipAddress               String?
  userAgent               String?
  viewedAt                DateTime?
  oscarCreatedAt          DateTime?
  oscarDemographicNo      String?
  oscarLastSyncAt         DateTime?
  cellPhone               String?
  gender                  String?
  middleName              String?
  newsletterOptIn         Boolean       @default(false)
  preferredLanguage       String?
  primaryLanguage         String?
  title                   String?
  workPhone               String?
  appointments            Appointment[]
  dependents              Dependent[]
  messages                Message[]

  @@map("patient_intakes")
}

model Message {
  id              String        @id @default(cuid())
  patientIntakeId String
  content         String
  subject         String?
  senderType      SenderType
  senderName      String
  senderEmail     String?
  adminUserId     String?
  isRead          Boolean       @default(false)
  readAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  ipAddress       String?
  userAgent       String?
  patientIntake   PatientIntake @relation(fields: [patientIntakeId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Dependent {
  id                             String        @id @default(cuid())
  patientIntakeId                String
  legalFirstName                 String
  legalLastName                  String
  healthInformationNumber        String
  dateOfBirth                    String
  gender                         String
  relationship                   String
  residenceAddressSameAsSection1 Boolean
  residenceApartmentNumber       String
  residenceStreetAddress         String
  residenceCity                  String
  residencePostalCode            String
  createdAt                      DateTime      @default(now())
  updatedAt                      DateTime      @updatedAt
  patientIntake                  PatientIntake @relation(fields: [patientIntakeId], references: [id], onDelete: Cascade)

  @@map("dependents")
}

model AdminUser {
  id                   String     @id @default(cuid())
  email                String     @unique
  passwordHash         String
  name                 String
  role                 AdminRole  @default(ADMIN)
  lastLoginAt          DateTime?
  loginAttempts        Int        @default(0)
  lockedUntil          DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  twoFactorBackupCodes String[]
  twoFactorEnabled     Boolean    @default(false)
  twoFactorSecret      String?
  auditLogs            AuditLog[]

  @@map("admin_users")
}

model BlogPost {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  content         String
  excerpt         String?
  featured        Boolean       @default(false)
  published       Boolean       @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  categoryId      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String
  tags            BlogPostTag[]
  category        BlogCategory? @relation(fields: [categoryId], references: [id])

  @@map("blog_posts")
}

model BlogCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  color       String?
  orderIndex  Int        @default(0)
  published   Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  blogPosts   BlogPost[]

  @@map("blog_categories")
}

model BlogTag {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String?
  color       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  blogPosts   BlogPostTag[]

  @@map("blog_tags")
}

model BlogPostTag {
  id         String   @id @default(cuid())
  blogPostId String
  blogTagId  String
  createdAt  DateTime @default(now())
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  blogTag    BlogTag  @relation(fields: [blogTagId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, blogTagId])
  @@map("blog_post_tags")
}

model FAQ {
  id         String   @id @default(cuid())
  question   String
  answer     String
  category   String?
  orderIndex Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("faqs")
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  title       String
  bio         String?
  photoUrl    String?
  email       String?
  phone       String?
  specialties String[]
  orderIndex  Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("team_members")
}

model AuditLog {
  id         String     @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime   @default(now())
  user       AdminUser? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Appointment {
  id                    String         @id @default(cuid())
  patientIntakeId       String?
  providerType          String
  providerAppointmentId String?
  providerName          String?
  patientName           String
  patientEmail          String
  patientPhone          String
  appointmentDate       String
  appointmentTime       String
  appointmentType       String
  duration              Int?
  providerId            String?
  providerStaffName     String?
  status                String
  notes                 String?
  reminderSent          Boolean        @default(false)
  confirmationSent      Boolean        @default(false)
  bookingUrl            String?
  metadata              Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  oscarAppointmentId    String?
  oscarCreatedAt        DateTime?
  oscarLastSyncAt       DateTime?
  oscarProviderNo       String?
  patientIntake         PatientIntake? @relation(fields: [patientIntakeId], references: [id])

  @@map("appointments")
}

model BookingProvider {
  id        String   @id @default(cuid())
  name      String
  type      String   @unique
  active    Boolean  @default(false)
  isDefault Boolean  @default(false)
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("booking_providers")
}

model NotificationTemplate {
  id           String             @id @default(cuid())
  name         String
  type         NotificationType
  method       NotificationMethod
  subject      String?
  message      String
  triggerHours Int
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  createdBy    String

  @@map("notification_templates")
}

model OscarJobQueue {
  id            String            @id @default(cuid())
  jobType       OscarJobType
  priority      JobPriority       @default(NORMAL)
  status        JobStatus         @default(PENDING)
  payload       Json
  result        Json?
  error         Json?
  attemptCount  Int               @default(0)
  maxAttempts   Int               @default(3)
  nextRetryAt   DateTime?
  scheduledAt   DateTime          @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  resourceType  String?
  resourceId    String?
  correlationId String?
  createdBy     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  jobHistory    OscarJobHistory[]

  @@index([status, scheduledAt])
  @@index([jobType, status])
  @@index([resourceType, resourceId])
  @@index([nextRetryAt])
  @@map("oscar_job_queue")
}

model OscarJobHistory {
  id            String          @id @default(cuid())
  jobId         String
  attemptNumber Int
  status        JobStatus
  startedAt     DateTime
  completedAt   DateTime
  duration      Int?
  success       Boolean
  result        Json?
  error         Json?
  errorType     OscarErrorType?
  executedBy    String?
  serverInfo    Json?
  job           OscarJobQueue   @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, attemptNumber])
  @@index([startedAt])
  @@map("oscar_job_history")
}

model OscarErrorLog {
  id                 String         @id @default(cuid())
  errorType          OscarErrorType
  errorCode          String?
  severity           ErrorSeverity  @default(ERROR)
  operation          String
  resourceType       String?
  resourceId         String?
  correlationId      String?
  message            String
  details            Json?
  resolved           Boolean        @default(false)
  resolvedAt         DateTime?
  resolvedBy         String?
  resolution         String?
  retryable          Boolean        @default(true)
  retryCount         Int            @default(0)
  lastRetryAt        DateTime?
  notificationSent   Boolean        @default(false)
  notificationSentAt DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([errorType, severity])
  @@index([operation, createdAt])
  @@index([resolved, severity])
  @@index([createdAt])
  @@map("oscar_error_log")
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  features    String[]
  icon        String?
  orderIndex  Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemSettings {
  id                   String   @id @default(cuid())
  primaryPhone         String
  emergencyPhone       String?
  faxNumber            String?
  adminEmail           String
  businessHours        String
  timezone             String   @default("America/Toronto")
  dateFormat           String   @default("MM/DD/YYYY")
  emailNotifications   Boolean  @default(true)
  appointmentReminders Boolean  @default(true)
  securityAlerts       Boolean  @default(true)
  maintenanceMode      Boolean  @default(false)
  sessionTimeout       Int      @default(30)
  maxLoginAttempts     Int      @default(5)
  passwordExpiry       Int      @default(90)
  twoFactorAuth        Boolean  @default(false)
  ipWhitelist          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  updatedBy            String?
  address              String   @default("Unit 216, 1980 Ogilvie Road, Gloucester, Ottawa, K1J 9L3")

  @@map("system_settings")
}

model ContactSubmission {
  id                      String          @id @default(cuid())
  name                    String
  email                   String
  phone                   String?
  healthInformationNumber String?
  subject                 String
  message                 String
  appointmentType         String?
  status                  ContactStatus   @default(NEW)
  priority                ContactPriority @default(NORMAL)
  assignedTo              String?
  respondedAt             DateTime?
  responseMessage         String?
  responseAdminId         String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  ipAddress               String?
  userAgent               String?
  originalMessageId       String?

  @@map("contact_submissions")
}

enum SenderType {
  PATIENT
  ADMIN
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
  SPAM
}

enum ContactPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum IntakeStatus {
  SUBMITTED
  REVIEWED
  APPOINTMENT_SCHEDULED
  CHECKED_IN
  COMPLETED
  CANCELLED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum NotificationType {
  APPOINTMENT_REMINDER
  APPOINTMENT_CONFIRMATION
  FOLLOW_UP
  GENERAL
}

enum NotificationMethod {
  EMAIL
  SMS
  BOTH
}

enum OscarJobType {
  PATIENT_CREATE
  PATIENT_UPDATE
  PATIENT_SEARCH
  APPOINTMENT_CREATE
  APPOINTMENT_UPDATE
  APPOINTMENT_CANCEL
  APPOINTMENT_SYNC
  PROVIDER_SYNC
  BULK_SYNC
  HEALTH_CHECK
  DATA_INTEGRITY_CHECK
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  DELAYED
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OscarErrorType {
  NETWORK_ERROR
  AUTHENTICATION_ERROR
  AUTHORIZATION_ERROR
  VALIDATION_ERROR
  RATE_LIMIT_ERROR
  TIMEOUT_ERROR
  SERVER_ERROR
  CLIENT_ERROR
  DATA_ERROR
  CONFIGURATION_ERROR
  UNKNOWN_ERROR
}

enum ErrorSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}
