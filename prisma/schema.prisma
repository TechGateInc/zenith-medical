generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PatientIntake {
  id                      String        @id @default(cuid())
  legalFirstName          String
  legalLastName           String
  preferredName           String?
  dateOfBirth             String
  phoneNumber             String
  emailAddress            String
  healthInformationNumber String
  streetAddress           String
  city                    String
  provinceState           String
  postalZipCode           String
  nextOfKinName           String
  nextOfKinPhone          String
  relationshipToPatient   String
  privacyPolicyAccepted   Boolean
  consentTimestamp        DateTime      @default(now())
  status                  IntakeStatus  @default(SUBMITTED)
  appointmentBooked       Boolean       @default(false)
  appointmentBookedAt     DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  ipAddress               String?
  userAgent               String?
  viewedAt                DateTime?

  cellPhone               String?
  gender                  String?
  middleName              String?
  newsletterOptIn         Boolean       @default(false)
  preferredLanguage       String?
  primaryLanguage         String?
  title                   String?
  workPhone               String?
  dependents              Dependent[]

  @@map("patient_intakes")
}



model Dependent {
  id                             String        @id @default(cuid())
  patientIntakeId                String
  legalFirstName                 String
  legalLastName                  String
  healthInformationNumber        String
  dateOfBirth                    String
  gender                         String
  relationship                   String
  residenceAddressSameAsSection1 Boolean
  residenceApartmentNumber       String
  residenceStreetAddress         String
  residenceCity                  String
  residencePostalCode            String
  createdAt                      DateTime      @default(now())
  updatedAt                      DateTime      @updatedAt
  patientIntake                  PatientIntake @relation(fields: [patientIntakeId], references: [id], onDelete: Cascade)

  @@map("dependents")
}

model AdminUser {
  id                   String     @id @default(cuid())
  email                String     @unique
  passwordHash         String
  name                 String
  role                 AdminRole  @default(ADMIN)
  lastLoginAt          DateTime?
  loginAttempts        Int        @default(0)
  lockedUntil          DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  auditLogs            AuditLog[]

  @@map("admin_users")
}

model BlogPost {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  content         String
  excerpt         String?
  featured        Boolean       @default(false)
  published       Boolean       @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  categoryId      String?
  authorId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String
  tags            BlogPostTag[]
  category        BlogCategory? @relation(fields: [categoryId], references: [id])
  author          TeamMember?   @relation(fields: [authorId], references: [id])

  @@map("blog_posts")
}

model BlogCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  color       String?
  orderIndex  Int        @default(0)
  published   Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  blogPosts   BlogPost[]

  @@map("blog_categories")
}

model BlogTag {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String?
  color       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  blogPosts   BlogPostTag[]

  @@map("blog_tags")
}

model BlogPostTag {
  id         String   @id @default(cuid())
  blogPostId String
  blogTagId  String
  createdAt  DateTime @default(now())
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  blogTag    BlogTag  @relation(fields: [blogTagId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, blogTagId])
  @@map("blog_post_tags")
}

model FAQ {
  id         String   @id @default(cuid())
  question   String
  answer     String
  category   String?
  orderIndex Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("faqs")
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  title       String
  bio         String?
  photoUrl    String?
  email       String?
  phone       String?
  orderIndex  Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // Doctor-specific fields
  isDoctor    Boolean  @default(false)
  credentials String?
  experience  String?
  education   String[]
  certifications String[]
  languages   String[]
  doctor      Doctor?
  blogPosts   BlogPost[]

  @@map("team_members")
}

model Doctor {
  id                    String   @id @default(cuid())
  teamMemberId          String   @unique
  professionalBio       String   @db.Text
  medicalSchool         String?
  graduationYear        Int?
  residency             String?
  fellowship            String?
  boardCertifications   String[]
  hospitalAffiliations  String[]
  researchInterests     String[]
  publications          String[]
  awards                String[]
  memberships           String[]
  consultationFee       String?
  availability          String?
  emergencyContact      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  teamMember            TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@map("doctors")
}

model AuditLog {
  id         String     @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime   @default(now())
  user       AdminUser? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  features    String[]
  icon        String?
  orderIndex  Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemSettings {
  id                   String   @id @default(cuid())
  primaryPhone         String
  emergencyPhone       String?
  faxNumber            String?
  adminEmail           String
  businessHours        String
  timezone             String   @default("America/Toronto")
  dateFormat           String   @default("MM/DD/YYYY")

  sessionTimeout       Int      @default(30)
  maxLoginAttempts     Int      @default(5)
  passwordExpiry       Int      @default(90)

  ipWhitelist          String?
  homepageImageUrl     String?
  appointmentBookingUrl String?
  patientIntakeUrl     String?
  whyChooseUsImageUrl  String?
  aboutMissionImageUrl String?
  servicesPaymentImageUrl String?
  
  // Announcement settings
  announcementEnabled  Boolean  @default(false)
  announcementTitle    String?
  announcementMessage  String?
  announcementType     String   @default("info") // info, warning, error, success
  announcementDisplay  String   @default("banner") // banner, popup, both
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  updatedBy            String?
  address              String   @default("Unit 216, 1980 Ogilvie Road, Gloucester, Ottawa, K1J 9L3")

  @@map("system_settings")
}

model ContactSubmission {
  id                      String          @id @default(cuid())
  name                    String
  email                   String
  phone                   String?
  healthInformationNumber String?
  subject                 String
  message                 String
  appointmentType         String?
  status                  ContactStatus   @default(NEW)
  priority                ContactPriority @default(NORMAL)
  assignedTo              String?
  respondedAt             DateTime?
  responseMessage         String?
  responseAdminId         String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  ipAddress               String?
  userAgent               String?
  originalMessageId       String?

  @@map("contact_submissions")
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
  SPAM
}

enum ContactPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum IntakeStatus {
  SUBMITTED
  REVIEWED
  APPOINTMENT_SCHEDULED
  CHECKED_IN
  COMPLETED
  CANCELLED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}


enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  DELAYED
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ErrorSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}
