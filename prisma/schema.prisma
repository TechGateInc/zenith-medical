generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  name          String
  role          AdminRole  @default(ADMIN)
  lastLoginAt   DateTime?
  loginAttempts Int        @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  auditLogs     AuditLog[]

  @@map("admin_users")
}

model BlogPost {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  content         String
  excerpt         String?
  featured        Boolean       @default(false)
  published       Boolean       @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  categoryId      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String
  authorId        String?
  locationId      String?
  tags            BlogPostTag[]
  author          TeamMember?   @relation(fields: [authorId], references: [id])
  category        BlogCategory? @relation(fields: [categoryId], references: [id])
  location        Location?     @relation(fields: [locationId], references: [id])

  @@map("blog_posts")
}

model BlogCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  color       String?
  orderIndex  Int        @default(0)
  published   Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  blogPosts   BlogPost[]

  @@map("blog_categories")
}

model BlogTag {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String?
  color       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  blogPosts   BlogPostTag[]

  @@map("blog_tags")
}

model BlogPostTag {
  id         String   @id @default(cuid())
  blogPostId String
  blogTagId  String
  createdAt  DateTime @default(now())
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  blogTag    BlogTag  @relation(fields: [blogTagId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, blogTagId])
  @@map("blog_post_tags")
}

model FAQ {
  id         String    @id @default(cuid())
  question   String
  answer     String
  category   String?
  orderIndex Int       @default(0)
  published  Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  @@map("faqs")
}

model Location {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  address              String
  city                 String
  province             String   @default("Ontario")
  postalCode           String
  primaryPhone         String
  emergencyPhone       String?
  faxNumber            String?
  email                String
  primaryColor         String   @default("#2563eb")
  secondaryColor       String   @default("#1e40af")
  heroImageUrl         String?
  bookingUrl           String?
  patientIntakeUrl     String?
  businessHours        String
  timezone             String   @default("America/Toronto")
  isActive             Boolean  @default(true)
  openingSoon          Boolean  @default(false)
  featured             Boolean  @default(false)
  acceptingNewPatients Boolean  @default(true)
  announcementEnabled  Boolean  @default(false)
  announcementTitle    String?
  announcementMessage  String?
  announcementType     String   @default("info")
  orderIndex           Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  services          Service[]
  uninsuredServices UninsuredService[]
  teamMembers       TeamMember[]
  faqs              FAQ[]
  blogPosts         BlogPost[]

  @@map("locations")
}

model TeamMember {
  id             String     @id @default(cuid())
  name           String
  title          String
  bio            String?
  photoUrl       String?
  email          String?
  phone          String?
  orderIndex     Int        @default(0)
  published      Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  certifications String[]
  credentials    String?
  education      String[]
  experience     String?
  isDoctor       Boolean    @default(false)
  languages      String[]
  locationId     String?
  blogPosts      BlogPost[]
  doctor         Doctor?
  location       Location?  @relation(fields: [locationId], references: [id])

  @@map("team_members")
}

model Doctor {
  id                   String     @id @default(cuid())
  teamMemberId         String     @unique
  professionalBio      String
  medicalSchool        String?
  graduationYear       Int?
  residency            String?
  fellowship           String?
  boardCertifications  String[]
  hospitalAffiliations String[]
  researchInterests    String[]
  publications         String[]
  awards               String[]
  memberships          String[]
  consultationFee      String?
  availability         String?
  emergencyContact     String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  bookingUrl           String?
  teamMember           TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@map("doctors")
}

model AuditLog {
  id         String     @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime   @default(now())
  user       AdminUser? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Service {
  id          String    @id @default(cuid())
  title       String
  description String
  features    String[]
  icon        String?
  orderIndex  Int       @default(0)
  published   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  imageUrl    String?
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id])
}

model UninsuredService {
  id          String    @id @default(cuid())
  category    String
  title       String
  description String?
  price       String
  isInsured   Boolean   @default(false)
  orderIndex  Int       @default(0)
  published   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id])

  @@map("uninsured_services")
}

model SystemSettings {
  id                      String   @id @default(cuid())
  primaryPhone            String
  emergencyPhone          String?
  faxNumber               String?
  adminEmail              String
  businessHours           String
  timezone                String   @default("America/Toronto")
  dateFormat              String   @default("MM/DD/YYYY")
  sessionTimeout          Int      @default(30)
  maxLoginAttempts        Int      @default(5)
  passwordExpiry          Int      @default(90)
  ipWhitelist             String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  updatedBy               String?
  address                 String   @default("Unit 216, 1980 Ogilvie Road, Gloucester, Ottawa, K1J 9L3")
  homepageImageUrl        String?
  appointmentBookingUrl   String?
  patientIntakeUrl        String?
  aboutMissionImageUrl    String?
  servicesPaymentImageUrl String?
  whyChooseUsImageUrl     String?
  announcementEnabled     Boolean  @default(false)
  announcementMessage     String?
  announcementTitle       String?
  announcementType        String   @default("info")
  announcementDisplay     String   @default("banner")
  acceptingNewPatients    Boolean  @default(true)
  defaultLocationId       String?

  @@map("system_settings")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  DELAYED
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ErrorSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}
