# Zenith Medical Centre - Environment Configuration Template
# Copy this file to .env and configure with your actual values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Next.js Application URL (used for redirects and absolute URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Application Environment (development, staging, production)
NODE_ENV=development

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database Connection
# Format: postgresql://username:password@hostname:port/database_name
DATABASE_URL=postgresql://username:password@localhost:5432/zenith_medical

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# NextAuth.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-this-in-production

# Encryption Keys (Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-256-bit-encryption-key-here
ENCRYPTION_IV=your-initialization-vector-here





# =============================================================================
# EMAIL NOTIFICATION SERVICES
# =============================================================================

# SendGrid Email Service
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@zenithmedical.ca
SENDGRID_FROM_NAME=Zenith Medical Centre

# Resend Email Service (Alternative to SendGrid)
RESEND_API_KEY=your-resend-api-key

# SMTP Configuration (Alternative email service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# =============================================================================
# SMS NOTIFICATION SERVICES
# =============================================================================

# Twilio SMS Service
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# CLOUD STORAGE (for file uploads, backups)
# =============================================================================

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console Verification
GOOGLE_SITE_VERIFICATION=your-google-search-console-verification-code

# Sentry Error Monitoring
SENTRY_DSN=your-sentry-dsn-url

# =============================================================================
# COMPLIANCE & AUDIT
# =============================================================================

# Audit Log Settings
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years for HIPAA compliance
AUDIT_LOG_LEVEL=info

# =============================================================================
# RATE LIMITING & SECURITY
# =============================================================================

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100     # Max requests per window
RATE_LIMIT_SKIP_FAILED_REQUESTS=true

# Security Headers
SECURITY_TRUSTED_ORIGINS=https://www.zenithmedical.ca,https://www.zenithmedical.ca

# =============================================================================
# BACKUP & MAINTENANCE
# =============================================================================

# Database Backup Configuration
BACKUP_SCHEDULE=0 2 * * *       # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================

# Enable debug logging in development
DEBUG=true

# Test environment settings
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/zenith_medical_test

# =============================================================================
# HIPAA/PIPEDA COMPLIANCE
# =============================================================================

# Compliance settings
HIPAA_COMPLIANT=true
PIPEDA_COMPLIANT=true
DATA_RETENTION_YEARS=7
ENCRYPTION_AT_REST=true
ENCRYPTION_IN_TRANSIT=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable features
FEATURE_TELEHEALTH=true
FEATURE_ONLINE_PAYMENTS=true
FEATURE_SMS_NOTIFICATIONS=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_APPOINTMENT_REMINDERS=true
FEATURE_PATIENT_PORTAL=true

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# Payment Processing (if enabled)
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Calendar Integration
GOOGLE_CALENDAR_CLIENT_ID=your-google-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# CONTACT INFORMATION
# =============================================================================

# Clinic Contact Information
CLINIC_NAME=Zenith Medical Centre
CLINIC_PHONE=+1-555-123-4567
CLINIC_EMAIL=admin@zenithmedical.ca
CLINIC_ADDRESS=123 Medical Plaza, Healthcare City, HC 12345

# Contact Information
CLINIC_CONTACT_PHONE=+1-555-911-0000
CLINIC_CONTACT_EMAIL=admin@zenithmedical.ca 